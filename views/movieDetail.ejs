<main>
    <div id="embed-container" style="display: none;">
        <div class="player-wrapper" id="player-wrapper">
            <div id="artplayer-container"></div>
            <iframe id="movie-player-fallback" style="display:none;" allowfullscreen></iframe>
        </div>
    </div>

    <section class="movie-hero" id="movie-hero">
        <div class="hero-overlay" id="hero-overlay">
            <div class="hero-info-center">
                <h1 id="det-title">Tên Phim</h1>
                <p id="det-tagline" class="tagline"></p>
                <div class="hero-actions">
                    <button class="btn-play-now" id="btn-play-now"><i class="fas fa-play"></i> Play Now</button>
                    <div class="action-icons">
                        <button><i class="fas fa-plus"></i></button>
                        <button><i class="fas fa-thumbs-up"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="container detail-content">
        <div class="col-left">
            <div class="card-section">
                <h2 id="det-title-body">Tên Phim</h2>
                <h3>Description</h3>
                <p id="det-description"></p>
            </div>

            <div class="card-section" id="episodes-section" style="display: none;">
                <div class="section-header">
                    <h3>Episodes / Seasons</h3>
                    <div class="season-selector">
                        <select id="season-select"></select>
                    </div>
                </div>
                <div class="episodes-grid" id="episodes-list"></div>
            </div>

            <div class="card-section">
                <div class="section-header">
                    <h3>Cast</h3>
                </div>
                <div class="cast-grid" id="cast-list"></div>
            </div>

            <div class="card-section">
                <div class="section-header">
                    <h3>Photos</h3>
                </div>
                <div class="photo-grid" id="photo-list">
                </div>
            </div>

            <div id="photo-modal" class="modal" onclick="this.style.display='none'">
                <span class="close">&times;</span>
                <img class="modal-content" id="full-photo">
            </div>
            <div class="card-section">
                <div class="section-header">
                    <h3>Reviews</h3>
                </div>
                <div class="reviews-container" id="reviews-list"></div>
            </div>
        </div>

        <div class="col-right">
            <div class="info-sidebar">
                <div class="info-item">
                    <label><i class="far fa-clock"></i> Duration</label>
                    <p id="det-runtime">--</p>
                </div>
                <div class="info-item">
                    <label><i class="far fa-calendar"></i> Year</label>
                    <p id="det-year"></p>
                </div>
                <div class="info-item">
                    <label><i class="fas fa-language"></i> Language</label>
                    <p id="det-languages"></p>
                </div>
                <div class="info-item">
                    <label><i class="far fa-star"></i> Rating</label>
                    <div class="rating-box" id="imdb-rating"></div>
                </div>
                <div class="info-item">
                    <label><i class="fas fa-th-large"></i> Genres</label>
                    <div class="tags" id="det-genres"></div>
                </div>
                <div class="info-item">
                    <label>Director</label>
                    <p id="det-director"></p>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    const API_KEY = '17409b8620a1b64c8f444a06b2788a41';
    const BASE_URL = 'https://api.themoviedb.org/3';
    const IMG_URL = 'https://image.tmdb.org/t/p/original';
    const CONSUMET_URL = 'https://apiconsumet-nine.vercel.app'; // Khuyên dùng: Thay bằng link Vercel của bạn
    const PROXY = "https://corsproxy.io/?";

    const urlParams = new URLSearchParams(window.location.search);
    const movieId = urlParams.get('id');
    const mediaType = urlParams.get('type') || 'movie';

    let art = null;
    let currentMovieData = null;

    if (!movieId) window.location.href = '/';

    // 1. Fetch Dữ liệu từ TMDB
    async function fetchMovieDetails() {
        const detailUrl = `${BASE_URL}/${mediaType}/${movieId}?api_key=${API_KEY}&language=vi-VN&append_to_response=credits,reviews,images&include_image_language=en,vi,null`;
        try {
            const response = await fetch(detailUrl);
            currentMovieData = await response.json();
            renderMovieDetails(currentMovieData);
            renderPhotos(currentMovieData.images.backdrops);
        } catch (error) {
            console.error('Lỗi lấy chi tiết:', error);
        }
    }

    function renderMovieDetails(movie) {
        const title = movie.title || movie.name;
        const year = (movie.release_date || movie.first_air_date || 'N/A').split('-')[0];

        document.getElementById('movie-hero').style.backgroundImage = `url(${IMG_URL}${movie.backdrop_path})`;
        document.getElementById('det-title').innerText = title;
        document.getElementById('det-title-body').innerText = title;
        document.getElementById('det-tagline').innerText = movie.tagline || '';
        document.getElementById('det-description').innerText = movie.overview || 'Không có mô tả.';
        document.getElementById('det-year').innerText = year;
        document.getElementById('det-languages').innerText = movie.original_language.toUpperCase();
        document.getElementById('imdb-rating').innerHTML = `<i class="fas fa-star" style="color:yellow;"></i> ${movie.vote_average.toFixed(1)} / 10`;

        if (mediaType === 'movie') {
            document.getElementById('det-runtime').innerText = `${movie.runtime} phút`;
            document.getElementById('episodes-section').style.display = 'none';
        } else {
            document.getElementById('det-runtime').innerText = movie.episode_run_time?.[0] ? `${movie.episode_run_time[0]} phút/tập` : 'N/A';
            renderSeasons(movie);
        }

        if (movie.genres) {
            document.getElementById('det-genres').innerHTML = movie.genres.map(g => `<span>${g.name}</span>`).join('');
        }

        if (movie.credits?.cast) {
            document.getElementById('cast-list').innerHTML = movie.credits.cast.slice(0, 6).map(actor => `
                <div class="cast-item">
                    <img src="${actor.profile_path ? 'https://image.tmdb.org/t/p/w200' + actor.profile_path : 'https://via.placeholder.com/100x150'}" alt="${actor.name}">
                    <p>${actor.name}</p>
                </div>
            `).join('');
        }
    }

    // 2. Xử lý Season & Episode
    function renderSeasons(movie) {
        const section = document.getElementById('episodes-section');
        const seasonSelect = document.getElementById('season-select');
        section.style.display = 'block';
        seasonSelect.innerHTML = movie.seasons.map(s => `<option value="${s.season_number}">Season ${s.season_number}</option>`).join('');
        seasonSelect.onchange = (e) => fetchEpisodes(movie.id, e.target.value);
        fetchEpisodes(movie.id, 1);
    }

    async function fetchEpisodes(tvId, seasonNum) {
        const url = `${BASE_URL}/tv/${tvId}/season/${seasonNum}?api_key=${API_KEY}&language=vi-VN`;
        const res = await fetch(url);
        const data = await res.json();
        const container = document.getElementById('episodes-list');
        container.innerHTML = data.episodes.map(ep => `
            <div class="episode-card" onclick="playEpisode(${ep.episode_number}, ${ep.season_number})">
                <img src="${ep.still_path ? 'https://image.tmdb.org/t/p/w300' + ep.still_path : 'https://via.placeholder.com/300x170'}" alt="${ep.name}">
                <div class="episode-card-info"><p>Tập ${ep.episode_number}: ${ep.name}</p></div>
            </div>
        `).join('');
    }


    async function getUniversalStream(id, type, title, s, e) {
        const baseUrl = CONSUMET_URL.endsWith('/') ? CONSUMET_URL.slice(0, -1) : CONSUMET_URL;

        try {
            // Ưu tiên lấy Original Name từ TMDB (VD: "Naruto" thay vì "ナルト")
            // Nếu không có original_name thì mới dùng title truyền vào
            let searchTitle = (currentMovieData.original_name || currentMovieData.original_title || title);

            // Làm sạch tên phim: Chỉ giữ lại chữ và số, bỏ các ký tự đặc biệt để API dễ tìm
            searchTitle = searchTitle.replace(/[^\w\s]/gi, '');

            console.log(`Đang tìm với tên: ${searchTitle}`);

            // 1. THỬ TMDB (Provider này ổn định nhất cho TV Series)
            const infoRes = await fetch(`${baseUrl}/meta/tmdb/info/${id}?type=${type}`);
            if (infoRes.ok) {
                const info = await infoRes.json();
                const targetEp = info.episodes?.find(ep => ep.season === parseInt(s) && ep.number === parseInt(e));
                if (targetEp) {
                    const watchRes = await fetch(`${baseUrl}/meta/tmdb/watch/${targetEp.id}?id=${id}`);
                    if (watchRes.ok) {
                        const watchData = await watchRes.json();
                        return watchData.sources.find(src => src.quality === 'auto')?.url || watchData.sources[0].url;
                    }
                }
            }

            // 2. THỬ GOGOANIME (Nếu TMDB 404 hoặc không có tập phim)
            // Encode chuẩn để tránh lỗi 404 do ký tự lạ
            const animeSearchUrl = `${baseUrl}/anime/gogoanime/${encodeURIComponent(searchTitle)}`;
            const searchRes = await fetch(animeSearchUrl);

            if (searchRes.ok) {
                const searchData = await searchRes.json();
                if (searchData.results && searchData.results.length > 0) {
                    const animeId = searchData.results[0].id;
                    const aInfo = await fetch(`${baseUrl}/anime/gogoanime/info/${animeId}`).then(res => res.json());
                    const aEp = aInfo.episodes.find(ep => ep.number === parseInt(e));
                    if (aEp) {
                        const aWatch = await fetch(`${baseUrl}/anime/gogoanime/watch/${aEp.id}`).then(res => res.json());
                        return aWatch.sources.find(src => src.quality === 'default')?.url || aWatch.sources[0].url;
                    }
                }
            }

        } catch (err) {
            console.warn("Lỗi fetch Consumet, đang chuyển dự phòng:", err.message);
        }
        return null; // Trả về null để dùng VidSrc Iframe
    }

    // 4. Player Control
    async function playEpisode(epNum, seasonNum) {
        document.getElementById('hero-overlay').style.display = 'none';
        document.getElementById('embed-container').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });

        const container = document.getElementById('artplayer-container');
        container.innerHTML = "<p style='color:white;text-align:center;padding-top:10%'>Đang lấy link phim sạch...</p>";

        // Sử dụng Original Title để tìm kiếm chính xác hơn
        const titleToSearch = currentMovieData.original_name || currentMovieData.original_title || currentMovieData.name;
        const streamUrl = await getUniversalStream(movieId, mediaType, titleToSearch, seasonNum, epNum);
        if (streamUrl) {
            initArtPlayer(streamUrl);
        }
        // } else {
        //     startFallback(mediaType === 'tv' 
        //         ? `https://vidsrc.to/embed/tv/${movieId}/${seasonNum}/${epNum}`
        //         : `https://vidsrc.to/embed/movie/${movieId}`);
        // }
    }

    function initArtPlayer(url) {
        document.getElementById('artplayer-container').style.display = 'block';
        document.getElementById('movie-player-fallback').style.display = 'none';
        if (art) art.destroy();
        art = new ArtPlayer({
            container: '#artplayer-container',
            url: url,
            type: 'm3u8',
            customType: {
                m3u8: (video, url) => {
                    if (Hls.isSupported()) {
                        const hls = new Hls();
                        hls.loadSource(url);
                        hls.attachMedia(video);
                    }
                }
            },
            fullscreen: true, setting: true, playbackRate: true,
        });
    }

    function startFallback(url) {
        document.getElementById('artplayer-container').style.display = 'none';
        const ifr = document.getElementById('movie-player-fallback');
        ifr.style.display = 'block';
        ifr.src = url;
    }

    function closePlayer() {
        document.getElementById('embed-container').style.display = 'none';
        document.getElementById('hero-overlay').style.display = 'block';
        if (art) art.pause();
        document.getElementById('movie-player-fallback').src = '';
    }

    document.getElementById('btn-play-now').onclick = () => {
        if (mediaType === 'movie') playEpisode(1, 1);
        else playEpisode(1, 1);
    };

    fetchMovieDetails();

    // Giữ nguyên hàm renderPhotos cũ của bạn
    function renderPhotos(backdrops) {
        const photoContainer = document.getElementById('photo-list');
        if (!backdrops.length) return photoContainer.innerHTML = '<p>Không có ảnh.</p>';
        photoContainer.innerHTML = backdrops.slice(0, 10).map(img => `
            <div class="photo-item"><img src="https://image.tmdb.org/t/p/w500${img.file_path}"></div>
        `).join('');
    }
</script>
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<script src="https://cdn.jsdelivr.net/npm/artplayer/dist/artplayer.js"></script>